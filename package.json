{
  "name": "agents-audit-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "homepage": "https://workspacejson.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workspace-json/agents-audit.git"
  },
  "bugs": {
    "url": "https://github.com/workspace-json/agents-audit/issues"
  },
  "dependencies": {
    "@workspacejson/rules": "workspace:*",
    "@workspacejson/spec": "workspace:*",
    "agents-audit": "workspace:*"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "release:verify-packs": "pnpm --filter @workspacejson/spec exec node ../../scripts/verify-package-tarball.mjs && pnpm --filter @workspacejson/rules exec node ../../scripts/verify-package-tarball.mjs && pnpm --filter agents-audit exec node ../../scripts/verify-package-tarball.mjs",
    "release:verify-published": "node scripts/verify-published.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
